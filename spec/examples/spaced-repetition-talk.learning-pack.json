      "id": "atom-spacing-effect",
      "kind": "model",
      "title": "The spacing effect",
      "summary": "Memory retention improves when study is distributed over time rather than massed.",
      "body": "Distributing repetitions across increasing intervals produces stronger long-term retention than the same number of repetitions packed together. Boundary: holds for durable factual/conceptual recall; less relevant for one-off or purely procedural motor tasks.",
      "review_state": "published",
      "authored_by": "mixed",
      "anchors": [{ "anchor_id": "anc-spacing", "support_state": "supports" }],
      "derivation_id": "der-edit",
      "version": 2
    },
    {
      "id": "atom-schedule-reviews",
      "kind": "system",
      "title": "Schedule reviews on expanding intervals",
      "summary": "A procedure for spacing reviews of a fact set.",
      "body": "Operational procedure derived from the spacing effect.",
      "steps": [
        { "text": "Split material into atomic items (one fact per item).", "anchor_id": "anc-schedule" },
        { "text": "Review a new item the same day, then after 1 day." },
        { "text": "On each successful recall, multiply the next interval (e.g. x2-2.5)." },
        { "text": "On a failed recall, reset the interval to 1 day." }
      ],
      "review_state": "published",
      "authored_by": "ai",
      "anchors": [{ "anchor_id": "anc-schedule", "support_state": "supports" }],
